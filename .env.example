# cochranblock-mail environment variables
# Copy to .env and fill in values before running.

# Required
MAIL_DOMAIN=cochranblock.org

# Ports (defaults shown)
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
IMAP_PORT=993
HTTP_PORT=8080

# Storage
MAIL_DIR=/var/lib/cochranblock-mail/messages
MAIL_DB=/var/lib/cochranblock-mail/mail.redb

# Frontend assets (built by: cd frontend && trunk build --release)
FRONTEND_DIST=frontend/dist

# Session TTL in seconds (default 86400 = 24h)
SESSION_TTL_SECS=86400

# Logging
RUST_LOG=info
